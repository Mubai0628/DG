{
  "name": "@deepseek-workbench/app",
  "version": "0.1.0",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "description": "Tauri desktop shell for local DeepSeek Workbench flows.",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 5179 --strictPort",
    "tauri:dev": "tauri dev",
    "build": "tsc -p tsconfig.json && vite build",
    "tauri:build": "tauri build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run test && cargo test --manifest-path src-tauri/Cargo.toml",
    "preflight": "node scripts/preflight.mjs",
    "smoke": "pnpm typecheck && pnpm test && pnpm preflight && node scripts/smoke.mjs",
    "manual-smoke:check": "node scripts/manual-smoke-check.mjs",
    "qa:check": "node scripts/qa-check.mjs"
  },
  "dependencies": {
    "@deepseek-workbench/runtime": "workspace:*",
    "@tauri-apps/api": "^2.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "@types/node": "24.13.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.0.0",
    "typescript": "6.0.3",
    "vite": "^7.0.0",
    "vitest": "4.1.8"
  }
}

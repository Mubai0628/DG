{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "DeepSeek Workbench",
  "version": "0.1.0",
  "identifier": "local.deepseek-workbench.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://localhost:5179",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "DeepSeek Workbench",
        "width": 1120,
        "height": 780,
        "minWidth": 860,
        "minHeight": 620
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": false,
    "targets": "all"
  }
}
